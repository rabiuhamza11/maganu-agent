# ============ MAGANU AGENT CONFIG ============
# Copy this to .env and fill in your values

# AI Brain — Groq (FREE, ultra-fast)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (send /start to @userinfobot to get it)
OWNER_CHAT_ID=your_telegram_chat_id_here

# Your Railway deployment URL (auto-set after deploy)
WEBHOOK_URL=https://maganu-agent.up.railway.app

# Security
WEBHOOK_SECRET=maganu_secret_change_this

# Server
PORT=3000
NODE_ENV=production
